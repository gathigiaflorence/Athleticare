<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Injury Area"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- GRID -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="true"
            android:alignmentMode="alignMargins">

            <!-- KNEE -->
            <LinearLayout
                android:id="@+id/cardKnee"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/knee"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Knee"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- SHOULDER -->
            <LinearLayout
                android:id="@+id/cardShoulder"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/shoulder"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Shoulder"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- BACK -->
            <LinearLayout
                android:id="@+id/cardBack"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/back"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Back"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- QUAD -->
            <LinearLayout
                android:id="@+id/cardQuad"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/quad"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Quad"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- HAMSTRING -->
            <LinearLayout
                android:id="@+id/cardHamstring"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/hamstring"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Hamstring"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- ANKLE -->
            <LinearLayout
                android:id="@+id/cardAnkle"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ankle"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Ankle"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- GROIN -->
            <LinearLayout
                android:id="@+id/cardGroin"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/groin"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Groin"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- ELBOW -->
            <LinearLayout
                android:id="@+id/cardElbow"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/elbow"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Elbow"
                    android:textColor="#16A34A"/>
            </LinearLayout>

            <!-- WRIST -->
            <LinearLayout
                android:id="@+id/cardWrist"
                style="@style/InjuryCard"
                android:backgroundTint="#F8FAFC">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/wrist"/>

                <TextView
                    style="@style/InjuryText"
                    android:text="Wrist"
                    android:textColor="#16A34A"/>
            </LinearLayout>

        </GridLayout>

    </LinearLayout>
</ScrollView>