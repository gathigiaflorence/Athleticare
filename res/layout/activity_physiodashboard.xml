<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

   
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/cardLogout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/appLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/login_background"
                    android:scaleType="fitCenter"
                    android:contentDescription="App Logo"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/appName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AthletiCare"
                    android:textSize="26sp"
                    android:textStyle="bold|italic"
                    android:textColor="#16A34A"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/appMotto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Injury Recovery Starts Here"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#64748B"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp" />
            </LinearLayout>

          
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E293B"
                android:layout_marginBottom="14dp" />

         
            <TextView
                android:id="@+id/welcomeTextPhysio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, Physio!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#16A34A"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage player injuries and recovery"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="24dp" />

           
            <LinearLayout
                android:id="@+id/cardAddInjury"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/rounded_white_card"
                android:backgroundTint="#F8FAFC"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕ Add Injury"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
            </LinearLayout>

           
            <LinearLayout
                android:id="@+id/cardViewInjuries"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/rounded_white_card"
                android:backgroundTint="#F8FAFC"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 View Injuries"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
            </LinearLayout>

           
            <LinearLayout
                android:id="@+id/cardAppointments"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/rounded_white_card"
                android:backgroundTint="#F8FAFC"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Appointments"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
            </LinearLayout>

           
            <LinearLayout
                android:id="@+id/cardFollowUp"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/rounded_white_card"
                android:backgroundTint="#F8FAFC"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 Follow-Up Cases"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

   
    <LinearLayout
        android:id="@+id/cardLogout"
        android:layout_width="140dp"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/rounded_white_card"
        android:backgroundTint="#F8FAFC"
        android:elevation="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚪 Logout"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#DC2626" />
    </LinearLayout>

</RelativeLayout>
