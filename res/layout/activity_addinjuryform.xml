<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Injury Record"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

       
        <TextView
            android:id="@+id/textBodyPart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Body Part: -"
            android:textStyle="bold"
            android:textColor="#F8FAFC"
            android:layout_marginBottom="12dp"/>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_white_card"
            android:backgroundTint="#F8FAFC"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/editTextSearchId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search Student ID"
                android:padding="12dp"
                android:textColor="#0F172A"
                android:textColorHint="#64748B"/>

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search Student"
                android:layout_marginTop="8dp"
                android:backgroundTint="#16A34A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

       
        <TextView
            android:id="@+id/textViewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: -"
            android:textColor="#F8FAFC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/textViewSport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sport: -"
            android:textColor="#F8FAFC"
            android:layout_marginBottom="16dp"/>

      
        <EditText
            android:id="@+id/editTextInjuryType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Injury Type (e.g. ACL sprain)"
            android:layout_marginBottom="12dp"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"/>

       
        <Spinner
            android:id="@+id/spinnerSeverity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Injury Date"
            android:textColor="#F8FAFC"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/textViewDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:padding="12dp"
            android:background="@drawable/rounded_white_card"
            android:backgroundTint="#F8FAFC"
            android:textColor="#0F172A"
            android:layout_marginBottom="16dp"/>

        
        <EditText
            android:id="@+id/editTextInjuryNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Clinical Notes"
            android:minLines="3"
            android:layout_marginBottom="12dp"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"/>

       
        <EditText
            android:id="@+id/editTextRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Recommendations / Rehab Plan"
            android:minLines="3"
            android:layout_marginBottom="20dp"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"/>

        
        <Button
            android:id="@+id/btnSaveInjury"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Injury Record"
            android:backgroundTint="#16A34A"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
